# .env.local — copy this to .env.local and fill in your values
# DO NOT commit .env.local to GitHub

# ─── Google Apps Script ───────────────────────────────────────────────────────
# Apps Script Web App URL (used by the browser to post form data)
# Get this after deploying your Apps Script as a Web App
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ─── WebSelfStorage (WSS) API ────────────────────────────────────────────────
# These are used server-side only (Next.js API routes). They are NEVER exposed
# to the browser — the intake form calls /api/wss-* which attaches the right
# key based on the customer's selected location.
#
# Each location has its own Entity ID (the number WSS assigns to that facility)
# and its own API key. Set the same values in Vercel → Project Settings → Env.

# Long Island City (LIC)
WSS_ENTITY_LIC=024642
WSS_API_KEY_LIC=YOUR_LIC_API_KEY_HERE

# Greenpoint (GP)
WSS_ENTITY_GP=038127
WSS_API_KEY_GP=YOUR_GP_API_KEY_HERE

# Williamsburg (NYC)
WSS_ENTITY_NYC=1023811
WSS_API_KEY_NYC=YOUR_NYC_API_KEY_HERE

# Jamaica (LIB)
WSS_ENTITY_LIB=1023807
WSS_API_KEY_LIB=YOUR_LIB_API_KEY_HERE
